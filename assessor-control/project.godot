config_version=5

[application]

config/name="Assessor-Control"
run/main_scene="uid://6epupytttkhs"
config/features=PackedStringArray("4.7", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

AudioManager="*uid://brq1vouri2dcj"
Dialogic="*uid://ds2q0uclmolvu"

[dialogic]

directories/dch_directory={
"伊利斯": "res://Characters/伊利斯.dch",
"希梅纳": "res://Characters/希梅纳.dch",
"我": "res://Characters/我.dch",
"金": "res://Characters/金.dch"
}
directories/dtl_directory={
"chapter1_ended": "res://Timelines/chapter1_ended.dtl",
"chapter1_finished": "res://Timelines/chapter1_finished.dtl",
"chapter1_pre": "res://Timelines/chapter1_pre.dtl"
}
layout/style_directory={}

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080

[editor_plugins]

enabled=PackedStringArray("res://addons/dialogic/plugin.cfg")

